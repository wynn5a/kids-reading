{
  "1-0": {
    "text": "天气凉了，树叶黄了，"
  },
  "1-1": {
    "text": "一片片叶子从树上落下来。"
  },
  "1-2": {
    "text": "天空那么蓝，那么高。"
  },
  "1-3": {
    "text": "一群大雁往南飞，"
  },
  "1-4": {
    "text": "一会儿排成个“人”字，"
  },
  "1-5": {
    "text": "一会儿排成个“一”字。"
  },
  "1-6": {
    "text": "啊！秋天来了！"
  },
  "2-0": {
    "text": "弯弯的月儿小小的船，"
  },
  "2-1": {
    "text": "小小的船儿两头尖。"
  },
  "2-2": {
    "text": "我在小小的船里坐，"
  },
  "2-3": {
    "text": "只看见闪闪的星星蓝蓝的天。"
  },
  "3-0": {
    "text": "江南可采莲，"
  },
  "3-1": {
    "text": "莲叶何田田。"
  },
  "3-2": {
    "text": "鱼戏莲叶间。"
  },
  "3-3": {
    "text": "鱼戏莲叶东，"
  },
  "3-4": {
    "text": "鱼戏莲叶西，"
  },
  "3-5": {
    "text": "鱼戏莲叶南，"
  },
  "3-6": {
    "text": "鱼戏莲叶北。"
  },
  "4-0": {
    "text": "草芽尖尖，"
  },
  "4-1": {
    "text": "他对小鸟说："
  },
  "4-2": {
    "text": "“我是春天。”"
  },
  "4-3": {
    "text": "荷叶圆圆，"
  },
  "4-4": {
    "text": "他对青蛙说："
  },
  "4-5": {
    "text": "“我是夏天。”"
  },
  "4-6": {
    "text": "谷穗弯弯，"
  },
  "4-7": {
    "text": "他鞠着躬说："
  },
  "4-8": {
    "text": "“我是秋天。”"
  },
  "5-0": {
    "text": "影子在前，"
  },
  "5-1": {
    "text": "影子在后，"
  },
  "5-2": {
    "text": "影子常常跟着我，"
  },
  "5-3": {
    "text": "就像一条小黑狗。"
  },
  "5-4": {
    "text": "影子在左，"
  },
  "5-5": {
    "text": "影子在右，"
  },
  "5-6": {
    "text": "影子常常陪着我，"
  },
  "5-7": {
    "text": "它是我的好朋友。"
  },
  "6-0": {
    "text": "谁的尾巴长？"
  },
  "6-1": {
    "text": "谁的尾巴短？"
  },
  "6-2": {
    "text": "谁的尾巴好像一把伞？"
  },
  "6-3": {
    "text": "猴子的尾巴长。"
  },
  "6-4": {
    "text": "兔子的尾巴短。"
  },
  "6-5": {
    "text": "松鼠的尾巴好像一把伞。"
  },
  "6-6": {
    "text": "谁的尾巴弯？"
  },
  "6-7": {
    "text": "谁的尾巴扁？"
  },
  "6-8": {
    "text": "谁的尾巴最好看？"
  },
  "7-0": {
    "text": "下雨了，"
  },
  "7-1": {
    "text": "雨点儿淅沥沥，沙啦啦。"
  },
  "7-2": {
    "text": "青蛙说：“我要写诗啦！”"
  },
  "7-3": {
    "text": "小蝌蚪游过来说："
  },
  "7-4": {
    "text": "“我要给你当个小逗号。”"
  },
  "7-5": {
    "text": "池塘里的水泡泡说："
  },
  "7-6": {
    "text": "“我能当个小句号。”"
  },
  "7-7": {
    "text": "荷叶上的一串水珠说："
  },
  "7-8": {
    "text": "“我们可以当省略号。”"
  },
  "7-9": {
    "text": "青蛙的诗写成了："
  },
  "7-10": {
    "text": "“呱呱，呱呱，"
  },
  "7-11": {
    "text": "呱呱呱。"
  },
  "7-12": {
    "text": "呱呱，呱呱，"
  },
  "7-13": {
    "text": "呱呱呱……”"
  },
  "8-0": {
    "text": "数不清的雨点儿，"
  },
  "8-1": {
    "text": "从云彩里飘落下来。"
  },
  "8-2": {
    "text": "半空中，大雨点儿问小雨点儿："
  },
  "8-3": {
    "text": "“你要到哪里去？”"
  },
  "8-4": {
    "text": "小雨点儿回答："
  },
  "8-5": {
    "text": "“我要去有花有草的地方。你呢？”"
  },
  "8-6": {
    "text": "大雨点儿说："
  },
  "8-7": {
    "text": "“我要去没有花没有草的地方。”"
  },
  "8-8": {
    "text": "不久，有花有草的地方，花更红了，"
  },
  "8-9": {
    "text": "草更绿了。"
  },
  "8-10": {
    "text": "没有花没有草的地方，"
  },
  "8-11": {
    "text": "开出了红的花，长出了绿的草。"
  },
  "9-0": {
    "text": "翻过来，"
  },
  "9-1": {
    "text": "唉睡不着。"
  },
  "9-2": {
    "text": "那地方的海，"
  },
  "9-3": {
    "text": "真的像老师说的，"
  },
  "9-4": {
    "text": "那么多种颜色吗？"
  },
  "9-5": {
    "text": "翻过去，"
  },
  "9-6": {
    "text": "唉睡不着。"
  },
  "9-7": {
    "text": "那地方的云，"
  },
  "9-8": {
    "text": "真的像同学说的，"
  },
  "9-9": {
    "text": "那么洁白柔软吗？"
  },
  "10-0": {
    "text": "有时候，我觉得自己很大。"
  },
  "10-1": {
    "text": "我自己穿衣服的时候，"
  },
  "10-2": {
    "text": "我自己系鞋带的时候，"
  },
  "10-3": {
    "text": "我觉得自己很大。"
  },
  "10-4": {
    "text": "有时候，我觉得自己很小。"
  },
  "10-5": {
    "text": "我够不到门铃的时候，"
  },
  "10-6": {
    "text": "我听到雷声喊妈妈的时候，"
  },
  "10-7": {
    "text": "我觉得自己很小。"
  },
  "11-0": {
    "text": "大海，蓝蓝的，又宽又远。"
  },
  "11-1": {
    "text": "沙滩，黄黄的，又长又软。"
  },
  "11-2": {
    "text": "雪白雪白的浪花，哗哗地笑着，"
  },
  "11-3": {
    "text": "涌向沙滩，"
  },
  "11-4": {
    "text": "悄悄撒下小小的海螺和贝壳。"
  },
  "11-5": {
    "text": "小娃娃嘻嘻地笑着，迎上去，"
  },
  "11-6": {
    "text": "捡起小小的海螺和贝壳，"
  },
  "11-7": {
    "text": "穿成彩色的项链，挂在胸前。"
  },
  "11-8": {
    "text": "快活的脚印落在沙滩上，"
  },
  "11-9": {
    "text": "穿成金色的项链，挂在大海胸前。"
  },
  "12-0": {
    "text": "下雪啦，下雪啦！"
  },
  "12-1": {
    "text": "雪地里来了一群小画家。"
  },
  "12-2": {
    "text": "小鸡画竹叶，小狗画梅花，"
  },
  "12-3": {
    "text": "小鸭画枫叶，小马画月牙。"
  },
  "12-4": {
    "text": "不用颜料不用笔，"
  },
  "12-5": {
    "text": "几步就成一幅画。"
  },
  "12-6": {
    "text": "青蛙为什么没参加？"
  },
  "12-7": {
    "text": "他在洞里睡着啦。"
  },
  "13-0": {
    "text": "一只乌鸦口渴了，到处找水喝。"
  },
  "13-1": {
    "text": "乌鸦看见一个瓶子，瓶子里有水。"
  },
  "13-2": {
    "text": "但是，瓶子里水不多，瓶口又小，"
  },
  "13-3": {
    "text": "乌鸦喝不着水。"
  },
  "13-4": {
    "text": "怎么办呢？"
  },
  "13-5": {
    "text": "乌鸦看见旁边有许多小石子，"
  },
  "13-6": {
    "text": "想出办法来了。"
  },
  "14-0": {
    "text": "蜗牛一家住在小树林的旁边。"
  },
  "14-1": {
    "text": "春天来了，蜗牛妈妈对小蜗牛说："
  },
  "14-2": {
    "text": "“孩子，到小树林里去玩吧，"
  },
  "14-3": {
    "text": "小树发芽了。”"
  },
  "14-4": {
    "text": "小蜗牛爬呀，爬呀，好久才爬回来。"
  },
  "14-5": {
    "text": "它说：“妈妈，小树长满了叶子，"
  },
  "14-6": {
    "text": "碧绿碧绿的，"
  },
  "14-7": {
    "text": "地上还长着许多草莓呢。”"
  },
  "14-8": {
    "text": "蜗牛妈妈说：“哦，已经是夏天了！"
  },
  "14-9": {
    "text": "快去摘几颗草莓回来。”"
  },
  "14-10": {
    "text": "小蜗牛爬呀，爬呀，好久才爬回来。"
  },
  "14-11": {
    "text": "它说：“妈妈，草莓没有了，"
  },
  "14-12": {
    "text": "地上长着蘑菇，树叶全变黄了。”"
  },
  "14-13": {
    "text": "蜗牛妈妈说：“哦，"
  },
  "14-14": {
    "text": "已经是秋天了！"
  },
  "14-15": {
    "text": "快去采几个蘑菇回来。”"
  },
  "14-16": {
    "text": "小蜗牛爬呀，爬呀，好久才爬回来。"
  },
  "14-17": {
    "text": "它说：“妈妈，蘑菇没有了，"
  },
  "14-18": {
    "text": "地上盖着雪，树叶全掉了。”"
  },
  "14-19": {
    "text": "蜗牛妈妈说：“哦，已经是冬天了！"
  },
  "14-20": {
    "text": "你就待在家里过冬吧。”"
  }
}
